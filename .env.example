# Proveedor activo: openrouter | bedrock
PROVIDER=bedrock

# ===== OpenRouter =====
OPENROUTER_API_KEY=sk-or-v1-pega-aqui-tu-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct
APP_NAME=LLM Gateway
APP_URL=http://localhost:8000

# ===== AWS Bedrock =====
# Bedrock se conecta SOLO con región + Bedrock API key (no IAM access key/secret).
AWS_REGION=us-east-1
# El string largo que termina en "=" (la "API key", no el "API key name").
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# Tope de salida en Bedrock (evita el corte por su default bajo). Nova 1 Lite ~5000; Nova 2 hasta 65000.
BEDROCK_MAX_OUTPUT_TOKENS=10000

# ===== Comunes =====
CORS_ORIGINS=["*"]
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
REQUEST_TIMEOUT=600

# Precio del modelo (USD por 1M tokens) para estimar costo. Default = Nova Lite.
PRICE_INPUT_PER_1M=0.06
PRICE_OUTPUT_PER_1M=0.24
