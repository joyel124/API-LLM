# Proveedor activo: openrouter | bedrock
PROVIDER=openrouter

# ----- OpenRouter -----
OPENROUTER_API_KEY=''
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modelo por defecto (este soporta PDF nativo). Otros con PDF nativo:
#   google/gemini-2.5-pro, openai/gpt-4o, anthropic/claude-opus-4
DEFAULT_MODEL=qwen/qwen3.5-397b-a17b

# Atribución (opcional, recomendada por OpenRouter)
APP_NAME=LLM Gateway
APP_URL=http://localhost:8000

# ----- Bedrock (rellenar cuando AWS entregue las credenciales) -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=

# ----- CORS -----
CORS_ORIGINS=["*"]